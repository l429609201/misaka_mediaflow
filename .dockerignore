# ==========================
# Docker 构建排除文件
# ==========================

# Git
.git
.gitignore
.github

# 依赖目录 (构建时重新安装)
web/node_modules
web/.cache
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache

# Go 编译产物 (构建时重新编译)
go-proxy/*.exe
go-proxy/*.exe~
go-proxy/go-proxy
go-proxy/mediaflow-proxy

# IDE
.vscode
.idea
*.swp
*.swo

# 本地配置 (不要打包进镜像)
config/config.yaml
config/logs/
config/strm/
config/*.db

# 文档/临时文件
docs/
*.md
!README.md
_ref_server.txt

# 前端构建产物 (构建时重新生成)
web/dist

# Docker
docker-compose*.yml
Dockerfile
.dockerignore

# ffmpeg 二进制：只保留当前构建目标架构，另一架构不需要进构建上下文
# 注意：实际排除由 CI 动态处理，此处排除非目标架构的目录
# amd64 构建时排除 arm64，arm64 构建时排除 amd64
# → 通过 Dockerfile ARG TARGETARCH + COPY 精确控制，两个都传进去也无害
# → 但为了减小构建上下文传输体积，排除 ffmpeg-image 下非必要文件
ffmpeg-image/amd64/*.tar
ffmpeg-image/amd64/*.xz
ffmpeg-image/arm64/*.tar
ffmpeg-image/arm64/*.xz
