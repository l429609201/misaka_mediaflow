# ===========================================
# Misaka MediaFlow 环境变量配置示例
# 复制为 .env 并根据实际情况修改
#
# 所有配置均使用 MISAKAMF_ 前缀
# 嵌套配置使用双下划线 __ 分隔
# ===========================================

# 通用
TZ=Asia/Shanghai

# 服务器
MISAKAMF_SERVER__HOST=0.0.0.0
MISAKAMF_SERVER__PORT=7789
MISAKAMF_SERVER__GO_PORT=9906
MISAKAMF_SERVER__LOG_LEVEL=info
# MISAKAMF_SERVER__EXTERNAL_URL=http://your-domain.com:7789

# 数据库
MISAKAMF_DATABASE__TYPE=postgresql
MISAKAMF_DATABASE__HOST=127.0.0.1
MISAKAMF_DATABASE__PORT=5432
MISAKAMF_DATABASE__NAME=mediaflow
MISAKAMF_DATABASE__USER=mediaflow
MISAKAMF_DATABASE__PASSWORD=your_strong_password

# 数据库 root 密码（仅 docker-compose 使用）
DB_ROOT_PASSWORD=your_strong_root_password

# Redis
MISAKAMF_REDIS__HOST=127.0.0.1
MISAKAMF_REDIS__PORT=6379
MISAKAMF_REDIS__PASSWORD=
MISAKAMF_REDIS__DB=0

# 媒体服务器
MISAKAMF_MEDIA_SERVER__TYPE=emby
MISAKAMF_MEDIA_SERVER__HOST=http://127.0.0.1:8096
MISAKAMF_MEDIA_SERVER__API_KEY=your_emby_api_key

# 安全
MISAKAMF_SECURITY__API_TOKEN=
MISAKAMF_SECURITY__ADMIN_PASSWORD=

# 初始管理员
MISAKAMF_ADMIN__INITIAL_USER=admin
MISAKAMF_ADMIN__INITIAL_PASSWORD=

